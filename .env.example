# Postgres (pgvector) — IFRS 인스턴스와 동일 host, DB만 분리
PG_DSN=postgresql://user:password@localhost:5432/audit_standards

# Embedding provider: "bge" (기본, 로컬 무료) | "upstage" (A/B eval 전용)
EMBED_PROVIDER=bge

# BGE-M3 로컬 (pip install "audit-parser[embedding-local]" 필요)
BGE_MODEL=BAAI/bge-m3

# Upstage — Task #3 A/B eval 시에만 사용 (audit_chunks_eval_upstage 임시 테이블)
# EMBED_PROVIDER=upstage
UPSTAGE_API_KEY=
UPSTAGE_EMBED_PASSAGE_MODEL=solar-embedding-1-large-passage
UPSTAGE_EMBED_QUERY_MODEL=solar-embedding-1-large-query
